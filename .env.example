# Copy to .env and fill in secrets as needed.
# Docker Compose loads this file automatically if you run: docker compose --env-file .env up

# AI
GEMINI_API_KEY=changeme
ANTHROPIC_API_KEY=changeme


# Midnight
MIDNIGHT_RPC_URL=https://rpc.devnet.midnight.network
MIDNIGHT_PROOF_SERVER_URL=https://proof-server.devnet.midnight.network
MIDNIGHT_PRIVATE_KEY=changeme
MIDNIGHT_NETWORK=devnet
MIDNIGHT_CONTRACT_ADDRESS=changeme
MIDNIGHT_ENABLED=true
MIDNIGHT_FALLBACK_MOCK_PROOFS=true
MIDNIGHT_LOG_REQUESTS=true

# Backend
DATABASE_URL=postgresql://verehire:verehire@db:5432/verehire
JWT_SECRET=changeme_generate_with_openssl_rand_-hex_32
MAX_RESUME_SIZE_MB=10

# Frontend -> Backend
NEXT_PUBLIC_API_URL=http://localhost:8000

